# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                   # Options: development | testing | production
APP_VERSION=1.0.0

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
# Local:      postgresql+asyncpg://postgres:password@localhost:5432/urlshortener
# Supabase:   postgresql+asyncpg://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/urlshortener
TEST_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/urlshortener_test

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local:   redis://localhost:6379
# Upstash: rediss://default:PASSWORD@HOST.upstash.io:PORT
REDIS_URL=redis://localhost:6379

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
# Local callback:      http://localhost:8000/api/v1/auth/github/callback
# Production callback: https://your-app.onrender.com/api/v1/auth/github/callback
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# ── Frontend / CORS ───────────────────────────────────────────────────────────
# MUST match your Vercel URL exactly — no trailing slash (required for HttpOnly cookies)
FRONTEND_URL=http://localhost:5173
# Comma-separated list of allowed origins for CORS (MUST be exact origins, no '*' or trailing slashes, for cookie credentials support)
ALLOWED_ORIGINS=http://localhost:5173

# ── API ───────────────────────────────────────────────────────────────────────
API_VERSION=v1

# ── Docs Auth (Basic Auth for /docs and /redoc) ───────────────────────────────
DOCS_USERNAME=admin
DOCS_PASSWORD=secure-admin-password
