				{
					"name": "Login User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.access_token) {",
									"    pm.environment.set(\"token\", res.access_token);",
									"    pm.environment.set(\"refresh_token\", res.refresh_token);",
									"}"
								],
